{
  "realm": "demo",
  "enabled": true,
  "displayName": "Demo realm for whoami scenario",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "clients": [
    {
      "clientId": "whoami-proxy",
      "name": "whoami oauth2-proxy",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "whoami-proxy-secret",
      "redirectUris": [
        "http://whoami.localhost:8088/oauth2/callback"
      ],
      "webOrigins": [
        "http://whoami.localhost:8088"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "web-origins"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "viewer"
      },
      {
        "name": "operator"
      }
    ]
  },
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "email": "demo@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "demopass",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer"
      ]
    }
  ]
}